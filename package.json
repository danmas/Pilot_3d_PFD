{
  "name": "pilot-3d-pfd",
  "private": true,
  "version": "2.12.3",
  "type": "module",
  "description": "Merged 3D Flight Viewer + PFD — bridge, viewer, and KPI in one project. Single npm run dev starts UDP bridge, SSE streams, HTTP API, capture and React PFD on port 3410.",
  "scripts": {
    "predev": "node scripts/kill-port.js 3410",
    "dev": "vite --strictPort",
    "build": "node prebuild.mjs && vite build && node -e \"const v=require('./package.json').version; const fs=require('fs'); fs.writeFileSync('.last-built-version', v)\"",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('captures',{recursive:true,force:true}); console.log('cleaned dist/ captures/')\"",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "three": "^0.184.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.1.3"
  }
}
